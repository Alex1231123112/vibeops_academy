# VibeOps — конфиг для HT
# Скопируйте в ht-admin/.env после клонирования HT

APP_ENV=dev
# Бот для канала @vibeops_academy (VibeOps Академия)
BOT_TOKEN=your-bot-token-from-botfather
MANAGER_USERNAME=vibeops_academy

# JWT и админ
JWT_SECRET=change-me-to-random-string
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-me

# Медиа: для локальной разработки
UPLOAD_BASE_URL=http://localhost:8000/uploads
# Для прода: UPLOAD_PUBLIC_BASE_URL=https://your-domain.com/uploads

# База (Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/botdb

# CORS
ALLOWED_ORIGINS=http://localhost:8800,http://localhost:5173
TIMEZONE=Europe/Moscow
